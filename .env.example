# ── Database ────────────────────────────────────────────────────────────────
# Local:   mysql://user:password@localhost:3306/loopline
# Aiven:   copy the "Service URI" from the Aiven console — SSL is automatic
DATABASE_URL="mysql://user:password@localhost:3306/loopline"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Local dev: install Mailpit (https://mailpit.axllent.org) and run `mailpit`
#            SMTP on localhost:1025 · Web UI at http://localhost:8025
#
# Production: use a free transactional email service, e.g.:
#   Brevo   → smtp-relay.brevo.com:587  (300 emails/day free)
#   Resend  → smtp.resend.com:465       (100 emails/day free)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="Loopline <noreply@loopline.app>"

# Optional – SMTP credentials (not needed for Mailpit)
# SMTP_USER=""
# SMTP_PASS=""

# ── App URL ──────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production, e.g. https://loopline.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
