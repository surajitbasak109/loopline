# ── Database ────────────────────────────────────────────────────────────────
# Local:   mysql://user:password@localhost:3306/loopline
# Aiven:   copy the "Service URI" from the Aiven console — SSL is automatic
DATABASE_URL="mysql://user:password@localhost:3306/loopline"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# ── Email ────────────────────────────────────────────────────────────────────
# Development: Mailpit (install: https://mailpit.axllent.org, run: `mailpit`)
#              Leave RESEND_API_KEY unset — Mailpit is used automatically.
#              Web UI: http://localhost:8025
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="Loopline <noreply@loopline.app>"

# Production: Resend (https://resend.com — 100 emails/day free)
#   1. Sign up → API Keys → Create API key
#   2. Add & verify your sending domain (or use onboarding@resend.dev to test)
#   3. Set RESEND_API_KEY — this automatically switches away from Mailpit
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ── App URL ──────────────────────────────────────────────────────────────────
# Set to your Vercel deployment URL in production, e.g. https://loopline.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
